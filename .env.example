# Application
SPRING_PROFILES_ACTIVE=prod
APP_PORT=8080

# PostgreSQL
POSTGRES_DB=spring_boot_lab
POSTGRES_USER=app_user
POSTGRES_PASSWORD=replace-with-a-long-random-password

# Spring Boot datasource
DB_URL=jdbc:postgresql://postgres:5432/spring_boot_lab
DB_USERNAME=app_user
DB_PASSWORD=replace-with-the-same-postgres-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# JWT
# Use a long random value. Never commit the real secret.
JWT_SECRET=<generate-with-openssl-rand-base64-64>

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
